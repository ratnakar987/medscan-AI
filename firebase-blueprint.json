{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created" }
      },
      "required": ["uid", "email"]
    },
    "MedicalReport": {
      "title": "Medical Report Analysis",
      "description": "Analysis results from a medical report scan",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the report" },
        "userId": { "type": "string", "description": "UID of the user who owns this report" },
        "fileName": { "type": "string", "description": "Name of the uploaded file" },
        "fileUrl": { "type": "string", "description": "URL of the file in Firebase Storage" },
        "analysis": {
          "type": "object",
          "properties": {
            "potential_diagnosis_guess": { "type": "string", "description": "AI-suggested diagnosis" },
            "holistic_summary": { "type": "string" },
            "easy_explanation": { "type": "string" },
            "key_findings": { "type": "array", "items": { "type": "string" } },
            "health_insights": { "type": "array", "items": { "type": "string" } },
            "precautions": { "type": "array", "items": { "type": "string" } },
            "next_steps": { "type": "array", "items": { "type": "string" } },
            "diet_recommendations": {
              "type": "object",
              "properties": {
                "to_eat": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "food": { "type": "string" },
                      "benefit": { "type": "string" }
                    }
                  }
                },
                "to_avoid": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "food": { "type": "string" },
                      "reason": { "type": "string" }
                    }
                  }
                }
              }
            },
            "medicine_list": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "dosage": { "type": "string" },
                  "purpose": { "type": "string" },
                  "timing": { "type": "string" },
                  "frequency": { "type": "string" }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created" }
      },
      "required": ["userId", "analysis", "createdAt"]
    },
    "Medicine": {
      "title": "Extracted Medicine",
      "description": "Information about a specific medicine extracted from a prescription",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "medicine_name": { "type": "string" },
        "dosage": { "type": "string" },
        "frequency": { "type": "string" },
        "timing": { "type": "string" },
        "use": { "type": "string" },
        "side_effects": { "type": "string" },
        "reportId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "medicine_name", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "reports/{reportId}": {
      "schema": "MedicalReport",
      "description": "Medical report analyses"
    },
    "medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Extracted medicines"
    }
  }
}
