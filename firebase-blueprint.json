{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" }
      },
      "required": ["uid", "email"]
    },
    "Report": {
      "title": "Medical Report",
      "description": "A scanned medical report and its AI analysis",
      "type": "object",
      "properties": {
        "report_id": { "type": "string", "description": "Unique report ID" },
        "user_id": { "type": "string", "description": "Owner's user ID" },
        "image_url": { "type": "string", "description": "URL to the stored image" },
        "analysis": { "type": "string", "description": "Full AI analysis JSON string" },
        "summary": { "type": "string", "description": "Brief summary of the report" },
        "status": { "type": "string", "enum": ["pending", "completed", "error"], "description": "Processing status" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the report was scanned" }
      },
      "required": ["report_id", "user_id", "image_url"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "A medicine extracted from a report",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner's user ID" },
        "reportId": { "type": "string", "description": "Source report ID" },
        "name": { "type": "string", "description": "Medicine name" },
        "dosage": { "type": "string", "description": "Dosage instructions" },
        "frequency": { "type": "string", "description": "Frequency of intake" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the medicine was added" }
      },
      "required": ["userId", "name"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Medical reports collection"
    },
    "/medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Medicines collection"
    }
  }
}
